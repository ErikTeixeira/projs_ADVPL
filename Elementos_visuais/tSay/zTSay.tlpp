user function zTGet

    Local oDlg1
    Local oButton1
    Local oSay

    oDlg1   := TDialog():New(0, 0, 400, 400, 'Exemplo TGet', , , , , , /*nCorFundo*/, , , .T.)

    oSay    := TSay():New(01,01,{||'Texto para exibińŃo'},oDlg1,,oFont,,,,.T.,CLR_RED,CLR_WHITE,200,20)

    oButton1 := TButton():New(80,10, "Executar", oDlg1, { || oDlg1:End() }, 60, 15,,,.F., .T., .F.,, .F.,,, .F.)

    oDlg1:Activate()

return


